{
  "name": "nestjs-bun-test",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "module": "src/main.ts",
  "scripts": {
    "build": "NODE_ENV=production bun run scripts/build.ts",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "NODE_ENV=development tsc && bun .",
    "start:dev": "NODE_ENV=development tsc-watch --onSuccess \"bun .\"",
    "start:debug": "NODE_ENV=development tsc-watch --onSuccess \"bun . --inspect\"",
    "start:prod": "NODE_ENV=production bun dist/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:cov": "bun test --coverage",
    "test:debug": "bun --inspect-brk --runInBand",
    "test:e2e": "bun test ./test/app.e2e-spec.ts"
  },
  "dependencies": {
    "@nestjs/cache-manager": "^3.0.1",
    "@nestjs/common": "^11.1.8",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.8",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.8",
    "@nestjs/sequelize": "^11.0.1",
    "@nestjs/swagger": "^11.2.1",
    "argon2": "^0.44.0",
    "bcrypt": "^6.0.0",
    "cache-manager": "^7.2.4",
    "class-transformer": "0.3.1",
    "class-transformer-storage": "^2.0.6",
    "class-validator": "^0.14.2",
    "colors": "^1.4.0",
    "express": "^5.1.0",
    "ioredis": "^5.8.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.3",
    "pg-hstore": "^2.3.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sequelize": "^6.37.7",
    "sequelize-typescript": "^2.1.6",
    "swagger-ui-dist": "^5.30.2",
    "umzug": "^3.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/testing": "^10.4.20",
    "@types/argon2": "^0.15.4",
    "@types/bcrypt": "^6.0.0",
    "@types/bun": "^1.3.2",
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.46.4",
    "@typescript-eslint/parser": "^8.46.4",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.6.2",
    "supertest": "^7.1.4",
    "ts-node": "^10.9.2",
    "tsc-watch": "^6.3.1",
    "typescript": "^5.9.3"
  },
  "trustedDependencies": [
    "@nestjs/core",
    "@scarf/scarf",
    "bcrypt"
  ]
}